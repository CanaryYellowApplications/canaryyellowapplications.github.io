---
const apps = [
	{
		name: 'The Set Lighting App',
		descriptor:
			'Set Lighting pocket resource. All the digital tools the modern Set Lighting Technician will need in the field and back in the truck. Databases! Formulas! Diagnostics! Reference Materials!',
		icon: '/app-icons/the-set-lighting-app.png',
		appleHref: 'https://apps.apple.com/us/app/the-set-lighting-app/id6753724639',
		appleBadge: '/store-badges/app-store.svg',
		appleAlt: 'Download on the App Store',
		googleHref:
			'https://play.google.com/store/apps/details?id=com.canaryyellowapplications.thesetlightingapp&pcampaignid=web_share',
	},
	{
		name: 'ScreenGlow Mobile',
		descriptor:
			'Mobile device luminaire. Fully functional tool for filmmakers to use their iOS device screen as a lighting device. Useful for both illumination from the display and as a screen chroma key. Modes include CCT, RGB, HSL, Party FX, TV FX, and DMX control via Art-Net or sACN traffic on the connected network.',
		icon: '/app-icons/screenglow-mobile.png',
		appleHref: 'https://apps.apple.com/us/app/screenglow-mobile/id6757760487',
		appleBadge: '/store-badges/app-store.svg',
		appleAlt: 'Download on the App Store',
		googleHref: null,
	},
	{
		name: 'ScreenGlow Desktop',
		descriptor:
			'Desktop Screen Luminaire. Fully functional tool for filmmakers to use their Mac screen as a lighting device. Useful for both illumination from the display and as a screen chroma key. Modes include CCT, RGB, HSL, Party FX, TV FX, and DMX control via Art-Net or sACN traffic on the connected network. Overlays include tracking marks and corner marks, plus display masks at various aspect ratios.',
		icon: '/app-icons/screenglow-desktop.png',
		appleHref: 'https://apps.apple.com/us/app/screenglow/id6753092394?mt=12',
		appleBadge: '/store-badges/mac-app-store.svg',
		appleAlt: 'Download on the Mac App Store',
		googleHref: null,
	},
	{
		name: 'LuxLog',
		descriptor:
			'Lighting Setup Logger. Keep track of every detail of your lighting setup. Includes inputs for illuminant color, brightness, DMX, modifiers, and positions, as well as camera settings, attachments, and more.',
		icon: '/app-icons/luxlog.png',
		appleHref: 'https://apps.apple.com/us/app/luxlog/id6755810780',
		appleBadge: '/store-badges/app-store.svg',
		appleAlt: 'Download on the App Store',
		googleHref: null,
	},
	{
		name: 'FalseColor+',
		descriptor:
			'Image analytics. Analyze and export any image using tools like False Color, Zebra, and Histogram.',
		icon: '/app-icons/falsecolor-plus.png',
		appleHref: 'https://apps.apple.com/app/falsecolor/id6757970490',
		appleBadge: '/store-badges/app-store.svg',
		appleAlt: 'Download on the App Store',
		googleHref: null,
	},
];

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Canary Yellow Applications</title>
		<meta
			name="description"
			content="A fresh local-first website starter for Canary Yellow Applications."
		/>
		<style>
			:root {
				--bg: #f6e39f;
				--bg-deep: #f1c94a;
				--ink: #1d1300;
				--ink-soft: rgba(29, 19, 0, 0.72);
				--card: rgba(255, 248, 221, 0.78);
				--line: rgba(29, 19, 0, 0.12);
				--shadow: 0 24px 80px rgba(113, 76, 0, 0.16);
				--radius: 28px;
			}

			* {
				box-sizing: border-box;
			}

			html {
				font-family: "Avenir Next", Avenir, "Helvetica Neue", sans-serif;
				color: var(--ink);
				background:
					radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 32%),
					linear-gradient(180deg, #fff5c7 0%, var(--bg) 52%, var(--bg-deep) 100%);
				min-height: 100%;
			}

			body {
				margin: 0;
				min-height: 100vh;
			}

			a {
				color: inherit;
			}

			.page {
				width: min(1120px, calc(100% - 2rem));
				margin: 0 auto;
				padding: 1rem 0 4rem;
			}

			.hero {
				position: relative;
				overflow: hidden;
				margin-top: 1rem;
				padding: 1.9rem 1rem 1rem;
				border: 1px solid var(--line);
				border-radius: calc(var(--radius) + 8px);
				background:
					linear-gradient(145deg, rgba(255, 250, 232, 0.96), rgba(255, 233, 138, 0.86)),
					#fff6d1;
				box-shadow: var(--shadow);
			}

			.hero::after {
				content: "";
				position: absolute;
				right: -6rem;
				top: -7rem;
				width: 18rem;
				height: 18rem;
				border-radius: 999px;
				background: rgba(255, 209, 41, 0.34);
				filter: blur(6px);
			}

			.hero-grid {
				position: relative;
				z-index: 1;
			}

			.hero-brand {
				display: flex;
				align-items: center;
				justify-content: space-between;
				width: 100%;
				padding-left: 1.75rem;
				margin-bottom: 1.1rem;
			}

			.hero-logo {
				display: block;
				width: min(283px, 55vw);
				max-height: 133px;
				flex: 0 0 auto;
				height: auto;
				object-fit: contain;
			}

			h1 {
				max-width: none;
				margin: 0;
				font-size: clamp(2rem, 4vw, 3.2rem);
				line-height: 0.92;
				letter-spacing: -0.05em;
				white-space: nowrap;
			}

			.hero-copy {
				display: none;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(12, 1fr);
				gap: 1rem;
				margin-top: 1rem;
			}

			.card {
				padding: 1.35rem;
				border: 1px solid var(--line);
				border-radius: var(--radius);
				background: var(--card);
				backdrop-filter: blur(10px);
				box-shadow: var(--shadow);
			}

			.card h2,
			.card h3 {
				margin: 0;
			}

			.card p,
			.card li {
				color: var(--ink-soft);
				line-height: 1.65;
			}

			.card ul {
				margin: 0.75rem 0 0;
				padding-left: 1.15rem;
			}

			.intro {
				grid-column: span 7;
			}

			.status {
				grid-column: span 5;
			}

			.apps {
				grid-column: 1 / -1;
			}

			.label {
				display: block;
				margin-bottom: 0.65rem;
				font-size: 1.7rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				text-align: center;
			}

			.app-list {
				display: flex;
				flex-direction: column;
				gap: 0.85rem;
				margin-top: 1rem;
				width: 100%;
			}

			.app-row {
				display: flex;
				align-items: center;
				gap: 1.15rem;
				min-height: 100%;
				padding: 1.15rem 1.2rem;
				border: 1px dashed rgba(29, 19, 0, 0.24);
				border-radius: 22px;
				background: rgba(255, 252, 242, 0.66);
				transition:
					transform 160ms ease,
					border-color 160ms ease,
					background 160ms ease;
			}

			.app-icon {
				width: 5rem;
				height: 5rem;
				flex: 0 0 auto;
				border-radius: 24px;
				border: 1px solid rgba(29, 19, 0, 0.1);
				object-fit: cover;
				box-shadow: 0 10px 24px rgba(113, 76, 0, 0.12);
				background: rgba(255, 255, 255, 0.85);
			}

			.app-copy {
				display: flex;
				flex-direction: column;
				gap: 0.3rem;
				flex: 1 1 auto;
				min-width: 0;
			}

			.app-name {
				font-size: 1.2rem;
				font-weight: 700;
				line-height: 1.25;
			}

			.app-desc {
				color: var(--ink-soft);
				font-size: 0.98rem;
				line-height: 1.55;
			}

			.store-actions {
				position: relative;
				z-index: 2;
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: 0.4rem;
				margin-left: auto;
				flex: 0 0 auto;
			}

			.store-badge {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				border-radius: 10px;
			}

			.store-badge img {
				display: block;
				height: 2.35rem;
				width: auto;
			}

			code {
				padding: 0.18rem 0.38rem;
				border-radius: 8px;
				background: rgba(29, 19, 0, 0.08);
				font-family: "SFMono-Regular", Menlo, monospace;
				font-size: 0.95em;
			}

			@media (max-width: 860px) {
				.apps {
					grid-column: 1 / -1;
				}

				.hero {
					padding-top: 3rem;
				}

				.hero-grid {
					grid-template-columns: 1fr;
				}

				.hero-brand {
					justify-content: space-between;
					padding-left: 0.75rem;
					margin-bottom: 1rem;
				}

				h1 {
					white-space: normal;
				}

				.app-row {
					align-items: flex-start;
					flex-wrap: wrap;
				}

				.app-icon {
					width: 4.5rem;
					height: 4.5rem;
				}

				.store-actions {
					width: 100%;
					margin-left: 0;
					padding-left: 5.65rem;
					align-items: flex-start;
					flex-direction: row;
					flex-wrap: wrap;
				}
			}

			.footer-nav {
				display: inline-flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: center;
				gap: 0.45rem;
				width: 100%;
				margin-top: 1.5rem;
				padding: 0 0 0.75rem;
				background: transparent;
				border: 0;
				border-radius: 0;
				box-shadow: none;
				color: var(--ink-soft);
				font-size: 0.9rem;
				line-height: 1;
			}

			.footer-link {
				text-decoration: none;
				font-weight: 400;
				letter-spacing: 0.01em;
			}

			.footer-link:hover,
			.footer-link:focus-visible {
				text-decoration: underline;
				outline: none;
			}

			.footer-separator {
				display: inline-block;
				color: rgba(29, 19, 0, 0.4);
				font-weight: 400;
				line-height: 1;
				transform: translateY(-0.02em);
			}
		</style>
	</head>
	<body>
		<main class="page">
			<section class="hero">
				<div class="hero-grid">
					<div class="hero-brand">
						<h1>Canary Yellow Applications</h1>
						<img class="hero-logo" src="/brand/cya-black.png" alt="Canary Yellow Applications" />
					</div>
				</div>
			</section>

			<section class="grid">
				<article class="card apps" id="apps">
					<span class="label">Our Apps</span>
					<div class="app-list">
						{
							apps.map((app) => (
								<div class="app-row">
									<img class="app-icon" src={app.icon} alt="" />
									<span class="app-copy">
										<span class="app-name">{app.name}</span>
										<span class="app-desc">{app.descriptor}</span>
									</span>
									<span class="store-actions">
										<a
											class="store-badge"
											href={app.appleHref}
											target="_blank"
											rel="noreferrer"
											aria-label={`${app.name} on Apple App Store`}
										>
											<img src={app.appleBadge} alt={app.appleAlt} />
										</a>
										{app.googleHref ? (
											<a
												class="store-badge"
												href={app.googleHref}
												target="_blank"
												rel="noreferrer"
												aria-label={`${app.name} on Google Play`}
											>
												<img src="/store-badges/google-play.png" alt="Get it on Google Play" />
											</a>
										) : null}
									</span>
								</div>
							))
						}
					</div>
				</article>

			</section>

			<nav class="footer-nav" aria-label="Footer">
				<a class="footer-link" href="/privacy.html">Privacy Policy</a>
				<span class="footer-separator" aria-hidden="true">|</span>
				<a class="footer-link" href="/terms.html">Terms of Use</a>
				<span class="footer-separator" aria-hidden="true">|</span>
				<a class="footer-link" href="/support.html">Support</a>
			</nav>
		</main>
	</body>
</html>
